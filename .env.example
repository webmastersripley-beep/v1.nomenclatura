VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLICA

# Frontend flag. Leave false while testing to avoid Gemini usage.
VITE_ENABLE_AI_ANALYSIS=false

# Optional. Leave empty in Vercel so the app uses /api/analyze-image.
# For local Express API, use http://localhost:3001
VITE_AI_API_URL=

# Backend/server key. Required only when VITE_ENABLE_AI_ANALYSIS=true.
GEMINI_API_KEY=TU_CLAVE_GEMINI
GEMINI_MODEL=gemini-2.5-flash-lite
